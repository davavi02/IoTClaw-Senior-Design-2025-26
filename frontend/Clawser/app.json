{
  "expo": {
    "name": "frontend",
    "slug": "clawser-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/claw_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "frontend",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "fonts": [
      "./assets/fonts/Jersey15-Regular.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iotclaw.frontend",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "frontend",
              "com.googleusercontent.apps.973669949194-qtpfvhlg1df90k37md12phfuru4r7974"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": [
          "googlechrome",
          "googlechromes"
        ]
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_NETWORK_STATE",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/claw_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.iotclaw.frontend",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "frontend"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "com.googleusercontent.apps.973669949194-claasjhgvpu9v9ops7iesps06t57f203"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "./app.plugin.js",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "signingConfig": {
              "storeFile": "../../credentials/debug.keystore",
              "storePassword": "android",
              "keyAlias": "androiddebugkey",
              "keyPassword": "android"
            }
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.973669949194-qtpfvhlg1df90k37md12phfuru4r7974"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "dcc9c5bf-ec21-4d88-91a9-d2f9d64025d4"
      }
    },
    "owner": "clawser-sd2026"
  }
}

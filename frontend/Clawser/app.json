{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/claw_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "frontend",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "fonts": ["./assets/fonts/Jersey15-Regular.ttf"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iotclaw.frontend",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "frontend",
              "com.googleusercontent.apps.973669949194-claasjhgvpu9v9ops7iesps06t57f203"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": [
          "googlechrome",
          "googlechromes"
        ]
      }
    },
    "android": {
      "permissions": ["CAMERA", "RECORD_AUDIO", "ACCESS_NETWORK_STATE", "MODIFY_AUDIO_SETTINGS"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/claw_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.iotclaw.frontend",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,

          "data": [
            {
              "scheme": "frontend"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "com.googleusercontent.apps.973669949194-claasjhgvpu9v9ops7iesps06t57f203"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "./app.plugin.js",
      [
        "expo-build-properties",
        {
          "android": 
          {
            "debugSigningConfig": {
            "storeFile": "../../credentials/debug.keystore",
            "storePassword": "android",
            "keyAlias": "androiddebugkey",
            "keyPassword": "android"
            }
          }
        }
      ]
    ]
  }
}
